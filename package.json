		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.8.3",
		"vite": "^8.0.10"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.10"
	}
}